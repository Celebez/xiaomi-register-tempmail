# ══════════════════════════════════════════════════════════════════
#  xiaomi-register-tempmail configuration
# ══════════════════════════════════════════════════════════════════

# ── Captcha solver (REQUIRED for real registration, not for --dry-run) ──
# Get yours from one of these (pick one — supports same RecaptchaV2Enterprise task):
#   2Captcha:         https://2captcha.com              (no free trial, $0.003/solve)
#   CapSolver:        https://dashboard.capsolver.com   ($1 free trial, no payment, $0.0015/solve) ← BEST DEAL
#   Anti-Captcha:     https://anti-captcha.com          ($5 free with phone verify, $0.002/solve)
#   CapMonster Cloud: https://capmonster.cloud          (refundable $5 trial, $0.0015/solve)
# Set the matching env var below (or use the generic CAPTCHA_API_KEY as fallback).
CAPTCHA_PROVIDER=capsolver
#TWOCAPTCHA_API_KEY=your_2captcha_key
CAPSOLVER_API_KEY=your_c...re
#ANTICAPTCHA_API_KEY=your_a...n
#CAPMONSTER_API_KEY=your_capmonster_key
# Or use a generic name (works for any provider)
#CAPTCHA_API_KEY=your_key_here

# ── Temp mail provider ──────────────────────────────────────────────
# Pick one: mailtm, guerrillamail, harakiri
# - mailtm:        Private inbox, 1 domain (web-library.net), rate-limited
# - guerrillamail: Rotates among 11+ domains, no signup, 60-min lifetime
# - harakiri:      Pick any name, no signup, public inbox, 1-hour expiry
TEMPMAIL_PROVIDER=guerrillamail

# ── Password used only for mailtm accounts ────────────────────────
# (Ignored when using guerrillamail or harakiri — no signup needed)
MAILTM_PASSWORD_BASE=MxBatchPass2026!

# ── HTTP proxy (optional) ──────────────────────────────────────────
# Uncomment to route Xiaomi registration requests through a proxy.
# Format: socks5://user:pass@host:port  OR  http://host:port
# HTTP_PROXY=socks5://127.0.0.1:40000

# ── HTTPS proxy alias (also supported) ────────────────────────────
# HTTPS_PROXY=socks5://127.0.0.1:40000