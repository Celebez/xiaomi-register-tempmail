# Required: 2Captcha API key for solving reCAPTCHA Enterprise
# Get yours at https://2captcha.com — top up $3-5 to start
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here

# Optional: Password to reuse for all mail.tm inboxes (simpler than per-account)
# Default if unset: MxBatchPass2026!
MAILTM_PASSWORD_BASE=MxBatchPass2026!

# Optional: HTTP proxy for the Xiaomi registration requests
# Format: socks5://user:pass@host:port or http://host:port
# HTTP_PROXY=socks5://127.0.0.1:40000